{
  "version": "2.0",
  "description": "动态评分心脏与反馈引擎配置 - 简化版",
  "level_scores": {
    "L1": {
      "score_correct": 20,
      "score_wrong": -10,
      "description": "入门概念题",
      "time_limit": 60,
      "difficulty_weight": 0.5
    },
    "L2": {
      "score_correct": 40,
      "score_wrong": -20,
      "description": "基础筑基题",
      "time_limit": 120,
      "difficulty_weight": 1.0
    },
    "L3": {
      "score_correct": 60,
      "score_wrong": -30,
      "description": "深度复合题",
      "time_limit": 180,
      "difficulty_weight": 1.5
    },
    "L4": {
      "score_correct": 100,
      "score_wrong": -50,
      "description": "巅峰压轴题",
      "time_limit": 300,
      "difficulty_weight": 2.0
    }
  },
  "level_indicators": {
    "mastered": {
      "color": "#10b981",
      "label": "已掌握",
      "description": "该等级节点已攻克"
    },
    "practicing": {
      "color": "#f59e0b",
      "label": "磨合中",
      "description": "该等级节点正在训练"
    },
    "failed": {
      "color": "#ef4444",
      "label": "未攻克",
      "description": "该等级节点需要强化"
    },
    "locked": {
      "color": "#6b7280",
      "label": "未解锁",
      "description": "该等级节点尚未解锁"
    }
  },
  "elo_question_distribution": {
    "L1": {
      "range": [0, 999],
      "recommended_levels": ["L1"],
      "multi_question": false,
      "description": "L1用户：只出L1单问题目"
    },
    "L2": {
      "range": [1000, 1799],
      "recommended_levels": ["L2"],
      "multi_question": false,
      "description": "L2用户：只出L2单问题目"
    },
    "L3": {
      "range": [1800, 2499],
      "recommended_levels": ["L2+L3"],
      "multi_question": true,
      "description": "L3用户：可出L2+L3两问题目"
    },
    "L4": {
      "range": [2500, 3000],
      "recommended_levels": ["L2+L4", "L3+L4"],
      "multi_question": true,
      "description": "L4用户：可出L2/3+L4两问题目"
    }
  },
  "feedback_templates": {
    "success": {
      "prefix": "🎯 精准命中！",
      "templates": [
        "${motif_name} 的 ${level} 节点已攻克，战力值 +${score}",
        "你的 ${weapon_name} 运用得当，${motif_name} 掌握度提升",
        "完美！${logic_core} 思路清晰，继续保持"
      ]
    },
    "partial": {
      "prefix": "⚠️ 部分命中",
      "templates": [
        "${motif_name} 的 ${level} 节点仍在磨合，建议复习 ${l4_trap}",
        "你的 ${weapon_name} 需要更多练习，注意 ${l4_trap}",
        "思路基本正确，但 ${l4_trap} 需要特别注意"
      ]
    },
    "failed": {
      "prefix": "❌ 壏离目标",
      "templates": [
        "${motif_name} 的 ${level} 节点未攻克，核心问题：${l4_trap}",
        "建议先掌握 ${prerequisite}，再挑战 ${motif_name}",
        "你的 ${weapon_name} 使用不当，${logic_core} 思路需要重建"
      ]
    },
    "decay_warning": {
      "prefix": "⏰ 记忆衰减预警",
      "templates": [
        "${motif_name} 已 ${days} 天未复习，知识正在衰减",
        "检测到 ${level} 节点记忆衰退，建议立即复习 ${l4_trap}",
        "战力退化警告：${motif_name} 需要重新激活"
      ]
    }
  },
  "question_combinations": {
    "L1": {
      "total_score": 20,
      "description": "纯入门题",
      "recommended_for": "L1 用户"
    },
    "L2": {
      "total_score": 40,
      "description": "纯基础题",
      "recommended_for": "L2 用户"
    },
    "L2+L3": {
      "total_score": 100,
      "description": "基础+进阶组合",
      "recommended_for": "L3 用户"
    },
    "L3": {
      "total_score": 60,
      "description": "纯进阶题",
      "recommended_for": "L2-L3 用户"
    },
    "L2+L4": {
      "total_score": 140,
      "description": "基础+巅峰组合",
      "recommended_for": "L4 用户"
    },
    "L3+L4": {
      "total_score": 160,
      "description": "进阶+巅峰组合",
      "recommended_for": "L3-L4 用户"
    },
    "L4": {
      "total_score": 100,
      "description": "纯巅峰题",
      "recommended_for": "L4 用户"
    },
    "L4+L4": {
      "total_score": 200,
      "description": "双巅峰组合",
      "recommended_for": "L4 用户冲刺满分"
    }
  }
}