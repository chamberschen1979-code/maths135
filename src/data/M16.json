          "master_benchmarks": [
            {
              "level": "L3",
              "id": "M16_V1.2_MB_L3_V96",
              "problem": "[基础巩固] 6 个人站成一排，甲不站在排头，乙不站在排尾，共有多少种不同的站法？",
              "logic_key": "正难则反 (容斥原理简化版)",
              "analysis": {
                "core_idea": "正面分类（甲在尾/甲在中间）较烦，用“总数 - 反面”更优。",
                "key_steps": [
                  "1. 计算总数：",
                  "   6 人全排：A(6,6) = 720。",
                  "2. 定义反面事件：",
                  "   A: 甲在排头。",
                  "   B: 乙在排尾。",
                  "   目标：求 N(非 A 且 非 B) = Total - N(A 或 B)。",
                  "3. 计算 N(A 或 B)：",
                  "   N(A 或 B) = N(A) + N(B) - N(A 且 B)。",
                  "   N(A) (甲在头): 剩 5 人全排 = 120。",
                  "   N(B) (乙在尾): 剩 5 人全排 = 120。",
                  "   N(A 且 B) (甲在头 且 乙在尾): 剩 4 人全排 = 24。",
                  "   N(A 或 B) = 120 + 120 - 24 = 216。",
                  "4. 计算结果：",
                  "   720 - 216 = 504。",
                  "5. 结论：504 种。"
                ],
                "common_pitfalls": [
                  "直接用 720 - 120 - 120 = 480，忘记加回重复减去的 N(A 且 B)。",
                  "正面分类时漏掉“甲在排尾”的情况。"
                ],
                "conclusion": "504"
              }
            },
            {
              "level": "L4",
              "id": "M16_V1.2_MB_L4_V96",
              "problem": "[2025·八省联考·T8 风格] 如图，用 4 种不同颜色给图中 A, B, C, D, E 五个区域染色，要求相邻区域颜色不同，则不同的染色方法共有多少种？\n(结构描述：C 为中心，连接 A,B,D,E；外围 A-B, B-E, E-D, D-A 依次相连形成一个环)。",
              "logic_key": "复杂染色问题的分类讨论",
              "analysis": {
                "core_idea": "经典轮图染色。核心是按顺序分步，并对“对角区域同色/异色”进行分类。",
                "key_steps": [
                  "1. 确定染色顺序：",
                  "   先染中心 C，再染外围 A, B, D, E。",
                  "2. 第一步：染 C。",
                  "   有 4 种选择。",
                  "3. 第二步：染外围 A, B, D, E。",
                  "   此时 C 已定，外围 4 个区域只能用剩余 3 种颜色。",
                  "   外围构成一个环 A-B-E-D-A。",
                  "   问题转化为：3 色染 4 区域环，相邻不同色。",
                  "4. 环形染色分类 (设颜色为 1,2,3)：",
                  "   按 A 和 E (对角) 是否同色分类：",
                  "   情况 1：A 与 E 同色。",
                  "     A 有 3 种，E 必须同色 (1 种)。",
                  "     B (夹在 A,E 间) 需不同于 A/E，有 2 种。",
                  "     D (夹在 A,E 间) 需不同于 A/E，有 2 种。",
                  "     小计：3 * 1 * 2 * 2 = 12。",
                  "   情况 2：A 与 E 异色。",
                  "     A 有 3 种，E 有 2 种 (不同于 A)。",
                  "     B 需不同于 A 且不同于 E (A,E 异色，占 2 色)，故 B 只有 1 种。",
                  "     D 需不同于 A 且不同于 E，故 D 只有 1 种。",
                  "     小计：3 * 2 * 1 * 1 = 6。",
                  "   外围总法：12 + 6 = 18。",
                  "5. 总计：",
                  "   4 (C) * 18 (外围) = 72。",
                  "6. 结论：72 种。"
                ],
                "common_pitfalls": [
                  "未对外围对角区域 (A,E) 是否同色进行分类，导致后续 B,D 的选择数无法确定。",
                  "环形染色公式记忆错误。",
                  "忽略中心 C 的颜色选择。"
                ],
                "conclusion": "72"
              }
            }
          ]
        }
      ]
